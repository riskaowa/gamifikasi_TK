# ============================================================================
# GAMIFIKASI PAUD - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# 
# IMPORTANT: Create a .env file in the project root with these variables.
# Never commit .env to version control!
# 
# For production hosting, set these values:

# Flask Configuration
# ============================================================================

# SECRET_KEY - REQUIRED for production
# Generate a secure key using: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_secret_key_here_generate_new_one

# Debug mode (only for development)
# Set to "False" for production
DEBUG=False

# Flask Environment
FLASK_ENV=production

# Application timezone
APP_TZ=Asia/Jakarta

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# 
# DEVELOPMENT (SQLite):
# DATABASE_URL=sqlite:///app.db
# 
# PRODUCTION (PostgreSQL - RECOMMENDED):
# DATABASE_URL=postgresql://username:password@host:5432/database_name
#
# PRODUCTION (MySQL):
# DATABASE_URL=mysql+pymysql://username:password@host:3306/database_name

DATABASE_URL=sqlite:///app.db

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Port (usually set by hosting platform, default 5000)
PORT=5000

# Bind to all interfaces
HOST=0.0.0.0

# ============================================================================
# OPTIONAL: ADDITIONAL CONFIGURATIONS
# ============================================================================

# Session cookie settings
SESSION_COOKIE_SECURE=True          # Only send over HTTPS
SESSION_COOKIE_HTTPONLY=True        # Prevent JavaScript access
SESSION_COOKIE_SAMESITE=Lax         # CSRF protection

# Maximum file upload size (bytes) - default 16MB
MAX_CONTENT_LENGTH=16777216

# Number of workers for production (use: 2 * CPU cores + 1)
WORKERS=3
